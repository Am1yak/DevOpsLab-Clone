version: "3.9"
name: hivemind-compose

services:
  redis:
    image: redis:7
    container_name: redis
    restart: always
    ports:
      - "6379:6379"
    networks:
      - backend

  dotnet-api:
    image: dotnet-api-image
    container_name: dotnet-api
    restart: always
    environment:
      Redis__ConnectionString: "redis:6379"
    ports:
      - "8080:8080"
    networks:
      - backend

  react-web:
    image: react-web-image
    container_name: react-web
    restart: always
    ports:
      - "3000:80"
    volumes:
      - ./config.json:/usr/share/nginx/html/config.json:ro,z
    networks:
      - backend

networks:
  backend: